// PARSE ERROR (rule 16, enforced by the grammar): only circle and triangle
// volumes exist; "square" is not a volume type.
bouldering_wall "SquareWall" {
  routes [
    bouldering_route "boxed in" {
      grade: "5A",
      grid_base_point { x: 0, y: 0 },
      holds ["0001", "0002"]
    }
  ],
  volumes [
    square {
      pos: { x: 50, y: 50 },
      depth: 10,
      front_holds [
        hold "0001" {
          pos: { x: 0, y: 0 },
          shape: "1",
          colours [ red ]
        },
        hold "0002" {
          pos: { x: 5, y: 5 },
          shape: "1",
          colours [ red ]
        }
      ]
    }
  ]
}
